# Backend
VSAF_ROOT=/home/jaekwang/visionspace
VSAF_HOST=127.0.0.1
VSAF_PORT=8000

# Model repositories. Use scripts/setup_model_repos.py to clone them.
TRIPOSR_REPO=/home/jaekwang/visionspace/models/repos/TripoSR
TRIPOSR_PYTHON=/home/jaekwang/visionspace/models/envs/triposr/bin/python

HUNYUAN3D_REPO=/home/jaekwang/visionspace/models/repos/Hunyuan3D-2
HUNYUAN3D_PYTHON=/home/jaekwang/visionspace/models/envs/hunyuan3d/bin/python
HUNYUAN3D_MODEL_PATH=tencent/Hunyuan3D-2mini
HUNYUAN3D_SUBFOLDER=hunyuan3d-dit-v2-mini
HUNYUAN3D_VARIANT=fp16
HUNYUAN3D_STEPS=50
HUNYUAN3D_OCTREE_RESOLUTION=380
HUNYUAN3D_NUM_CHUNKS=20000
HUNYUAN3D_SEED=12345

# Model caches. Keep large checkpoints out of the repo.
HF_HOME=/home/jaekwang/visionspace/models/cache/huggingface
HF_HUB_CACHE=/home/jaekwang/visionspace/models/cache/huggingface/hub
TORCH_HOME=/home/jaekwang/visionspace/models/cache/torch
U2NET_HOME=/home/jaekwang/visionspace/models/cache/u2net
HY3DGEN_MODELS=/home/jaekwang/visionspace/models/cache/hy3dgen

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Track 3 LLM parser
# 기본 동작은 vLLM(Qwen3.6) guided JSON 경로다. BASE_URL을 비우면 OpenAI 경로로 폴백된다.
OPENAI_API_KEY=EMPTY
VSAF_SCENE_PARSER_OPENAI_BASE_URL=http://localhost:8003/v1
VSAF_SCENE_PARSER_OPENAI_MODEL=local-main
VSAF_SCENE_PARSER_OPENAI_TIMEOUT_SECONDS=30
VSAF_SCENE_PARSER_OPENAI_MAX_OUTPUT_TOKENS=1800

# OpenAI를 쓰려면 위 BASE_URL을 비우고 아래 값을 채우면 된다.
# VSAF_SCENE_PARSER_OPENAI_BASE_URL=
# OPENAI_API_KEY=sk-...
# VSAF_SCENE_PARSER_OPENAI_MODEL=gpt-4o-mini
